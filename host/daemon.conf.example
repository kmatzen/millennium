# Millennium Daemon Configuration File
# Copy this file to /etc/millennium/daemon.conf and modify as needed

# Hardware Configuration
hardware.display_device=/dev/serial/by-id/usb-Arduino_LLC_Millennium_Beta-if00
hardware.baud_rate=9600

# Call Configuration
# A paid call dials automatically once 10 digits are entered (with enough
# coins). To place a shorter number (e.g. a 7-digit local number), press '#'
# to send immediately — the '#' request stays armed, so a coin inserted after
# pressing it still completes the call.
call.cost_cents=50
call.timeout_seconds=300
# Comma-separated numbers that can be dialed without coins (emergency/free calls)
call.free_numbers=911,311,0
# Seconds of inactivity (handset up, no dialing) before phone resets
call.idle_timeout_seconds=60

# SIP / VoIP Configuration (PJSIP / PJSUA)
# Credentials live here now (no separate ~/.baresip/accounts file). Leave
# sip.id_uri / sip.registrar empty to run the phone without VoIP (games only).
# Account-of-record URI (your DID @ provider domain):
sip.id_uri=
# Registrar URI (usually sip:<provider-domain>):
sip.registrar=
# Auth realm ("*" matches any realm the server offers):
sip.realm=*
sip.username=
sip.password=
# Signalling transport: udp | tcp | tls  (Twilio requires tls)
sip.transport=tls
# Optional STUN server for NAT traversal (host:port), e.g. stun.l.google.com:19302
sip.stun_server=
# Local SIP port (0 = auto/ephemeral)
sip.local_port=0
# ALSA sound device NAMES for the call leg (matched against PJSUA's device
# list; empty = PJSUA auto). The raw "hw:..." device is stereo-only and fails
# at mono telephony, so use plug-wrapped devices. Defaults route call audio to
# the handset earpiece (right channel) and capture the C-Media mic:
sip.snd_capture=plughw:CARD=Device,DEV=0
sip.snd_playback=out_right_solo

# Card Configuration (magstripe reader)
card.enabled=true
# Comma-separated 16-digit card numbers that grant free calling
card.free_cards=
# Comma-separated 16-digit card numbers that grant admin access
card.admin_cards=

# Logging Configuration - BALANCED for audio performance
logging.level=INFO
logging.file=/var/log/millennium/daemon.log
logging.to_file=true

# System Configuration
system.update_interval_ms=33
system.max_retries=3
# Source directory for OTA updates (git pull + rebuild)
system.source_dir=/home/matzen/millennium

# State Persistence
persistence.state_file=/var/lib/millennium/state

# Metrics Server Configuration
# Standalone Prometheus/JSON metrics endpoint. (Metrics are also always exposed
# via the web server at /api/metrics regardless of this setting.) Was disabled
# on the single-core Pi Zero W; re-enabled after the multicore upgrade.
metrics_server.enabled=true
metrics_server.port=8080

# Web Server Configuration
# Port 80 (privileged) — granted via CAP_NET_BIND_SERVICE in the systemd unit.
web_server.enabled=true
web_server.port=80

# Plugin Configuration
# Each plugin can read its own keys from this file. Built-in game plugins:
#   Number Guess (Hi-Lo)
guess.cost_cents=25
# guess.secret forces the hidden number 1..99 (0 = random; for testing/demos)
guess.secret=0
#   Simon (memory game, free to play)
# simon.seq forces the tone sequence, e.g. 1342 (empty = random)
simon.seq=
#   Dial-A-Joke (free joke line)
# joke.index forces a starting joke (-1 = random)
joke.index=-1
#   Trivia (free True/False quiz)
# trivia.start forces the first question index (-1 = random)
trivia.start=-1
