# The Operator: travel to a key era, LISTEN, and recover a number-piece; the HUD
# then points at the next piece.
activate_plugin The Operator
hook_up

# Dial the 1950s -> connecting beat -> the era
keys 1955
wait 3
assert_display 1=LISTEN
assert_clip era1_arrive.wav

# Listen (don't speak) -> first piece
key 1
assert_display PIECE A
assert_display 1/3
assert_clip era1_listen.wav

# After the reveal, back to the Operator pointing at piece B
wait 3
assert_display DIAL A YEAR
assert_display FIND THE 1970s
