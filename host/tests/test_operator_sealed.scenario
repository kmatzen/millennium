# The Operator: the final year is sealed; a magstripe pass (temporal pass) opens
# it, then LISTEN gives the last piece.
activate_plugin The Operator
hook_up

keys 1998
wait 3
assert_display SEALED
assert_clip era3_sealed.wav

# Swipe any card -> trunk-line pass -> the era opens
card 1234567890123456
assert_display 1998 A CARD
assert_clip era3_arrive.wav

key 1
wait 14
assert_display PIECE C
assert_display 1/3
