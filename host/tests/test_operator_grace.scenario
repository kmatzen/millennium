# The Operator: hanging up and lifting again within the grace window resumes the
# same session with progress kept; after the window it starts fresh.
activate_plugin The Operator
hook_up

# Solve puzzle 1
keys 484
assert_display GOT IT
wait 3
assert_display HER AGE IN 1999

# Hang up, lift back quickly -> resume at puzzle 2 (the 484 is kept)
hook_down
assert_state IDLE_DOWN
wait 5
hook_up
assert_display HER AGE IN 1999

# Finishing proves the assembled number still carries the 484 prefix
keys 51
wait 3
keys 58
wait 3
assert_display 484 51 58
