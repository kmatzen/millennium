# The Operator: solve all three puzzles, assemble her number, dial it, and the
# call connects -- turning the clock over to 2000.
activate_plugin The Operator
hook_up

# Puzzle 1 -- spell HUG on the keypad: 4-8-4
assert_display WORD BY THE PHONE
keys 484
assert_display GOT IT
assert_display HER #: 484
assert_clip solved.wav
wait 3

# Puzzle 2 -- her age in 1999 from the narrated facts: 51
assert_display HER AGE IN 1999
assert_clip puz2.wav
keys 51
assert_display HER #: 48451
wait 3

# Puzzle 3 -- decode the crossed line 7 0 by subtracting 2: 58
assert_display CROSSED: 7 0
assert_clip puz3.wav
keys 58
assert_display HER #: 4845158
wait 3

# All three solved -> dial the whole number
assert_display DIAL HER NUMBER
assert_display 484 51 58
assert_clip op_ready.wav
keys 4845158
assert_display RINGING
assert_clip final_connect.wav

# The clock turns over, and she is free, then a quiet coda
wait 8
assert_display the clock turns
wait 6
assert_display SHE IS FREE
assert_clip win_free.wav
wait 8
assert_display THE LINE IS QUIET
