# The Operator: the full arc -- collect all three pieces, dial the number, and
# the call connects, turning the clock over to 2000.
activate_plugin The Operator
hook_up

# Piece A (1950s)
keys 1955
wait 3
key 1
wait 3

# Piece B (1970s)
keys 1978
wait 3
key 1
wait 3

# Piece C (1998, sealed -> swipe a pass)
keys 1998
wait 3
assert_display SEALED
card 1234567890123456
key 1
wait 3

# All three pieces -> ready to place the call; the number is shown
assert_display DIAL HER NUMBER
assert_display 36 41 55
assert_clip op_ready.wav

# Dial Ruth's number -> the call connects
keys 364155
assert_display RINGING
assert_clip final_connect.wav

# The clock turns over, and she is free
wait 4
assert_display the clock turns
wait 5
assert_display SHE IS FREE
assert_clip win_free.wav
